# Book2Audiobook — Environment Variables
#
# Copy this file to `.env` and fill in your values.
# The app reads these at runtime; you can also configure them in
# Preferences → Backends instead of using environment variables.
#
# NOTE: .env is in .gitignore and will NOT be committed. Never commit real keys.

# OpenAI API key (cloud TTS backend)
OPENAI_API_KEY=

# OpenRouter API key (cloud TTS via OpenRouter)
OPENROUTER_API_KEY=
